# Cloudflare Pages response headers for heirloom.blue
# The API host (api.heirloom.blue) sets its own headers in the Worker; this file
# hardens the static frontend. CSP keeps script-src tight ('self' — the app's
# only JS is the hashed /assets bundle) while leaving resource directives broad
# enough not to break QR images (qrserver), the Wrapped audio cue (soundjay),
# Google Fonts, or XHR to the API. style-src allows 'unsafe-inline' because React
# + framer-motion write inline style attributes.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(self), camera=(self), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; frame-src 'self'; img-src 'self' data: blob: https:; media-src 'self' https:; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' https://static.cloudflareinsights.com; connect-src 'self' https://api.heirloom.blue https://cloudflareinsights.com; manifest-src 'self'; worker-src 'self'; form-action 'self'; upgrade-insecure-requests

# Content-hashed bundles are immutable — cache hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The service worker must never be stale-cached, or updates can't land.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=3600
