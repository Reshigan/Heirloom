# Production build env for heirloom.blue (Vite reads .env.production at `npm run build`).
# VAPID public key for Web Push — this is PUBLIC by design (the browser sends it as
# the applicationServerKey). It MUST match VAPID_PUBLIC_KEY on the worker. The matching
# private key is a Cloudflare Worker secret (VAPID_PRIVATE_KEY) and is never committed.
VITE_VAPID_PUBLIC_KEY=BDopBkNPk3AAbpKWLTR86GU_AjfOIPvw8zgt7XIAQbuD23eZL4p5Tit6MKv1MoGmkcrIAkduBWU6JBDFe3Uh08c
