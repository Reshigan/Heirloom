ANTHROPIC_API_KEY=
# Sonnet 4.6 default — ~$3/mo. Use claude-haiku-4-5 for ~$0.25/mo.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Direct platform APIs (free). Leave blank for queue mode (writes to output/).
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Discord/Slack webhook for queue-mode notifications (TikTok, X, Threads, YT
# Shorts get queued because they need expensive APIs or app reviews)
QUEUE_WEBHOOK_URL=

# Worker queue handoff (Layer B → Layer A integration). When set, the daily
# generator POSTs variants to /api/social/bulk-load instead of calling
# platform APIs directly. The worker's existing 5-minute Postiz cron then
# publishes them. This is the production path.
HEIRLOOM_API_URL=
HEIRLOOM_ADMIN_TOKEN=

# Comma-separated. Default: instagram,tiktok,pinterest,facebook,linkedin,x
PLATFORMS=instagram,tiktok,pinterest,facebook,linkedin,x
