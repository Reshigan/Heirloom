ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Leave AYRSHARE_API_KEY blank to run in DRY_RUN mode (writes to output/, no posts)
AYRSHARE_API_KEY=

# Comma-separated. Default: instagram,tiktok,pinterest,facebook,linkedin,x
# Full list: instagram, reels, tiktok, pinterest, facebook, linkedin, x, threads, bluesky, youtubeshorts
PLATFORMS=instagram,tiktok,pinterest,facebook,linkedin,x

# Set to 1 to force dry-run even with AYRSHARE_API_KEY set
DRY_RUN=
